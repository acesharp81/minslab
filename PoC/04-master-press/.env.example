# Add these names to the homepage repository root .env.
# Never commit real values.

# Official NAVER News Search API application credentials.
MASTER_PRESS_NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
MASTER_PRESS_NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET

# Kakao application used for recipient OAuth and "Send to me".
# KAKAO_REST_API_KEY can be reused when MASTER_PRESS_KAKAO_REST_API_KEY is omitted.
MASTER_PRESS_KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
MASTER_PRESS_KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
MASTER_PRESS_KAKAO_REDIRECT_URI=https://YOUR_DOMAIN/poc/master-press/oauth/kakao/callback

# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_PRESS_TOKEN_ENCRYPTION_KEY=YOUR_FERNET_KEY

# Local Ollama is reserved for embeddings/RAG only.
OLLAMA_BASE_URL=http://127.0.0.1:11434
MASTER_PRESS_EMBEDDING_MODEL=nomic-embed-text:latest

# Groq handles shared article classification, tone and summaries.
GROQ_API_KEY=YOUR_GROQ_API_KEY
MASTER_PRESS_GROQ_BASE_URL=https://api.groq.com/openai/v1
MASTER_PRESS_GROQ_COMMON_MODEL=llama-3.1-8b-instant
MASTER_PRESS_GROQ_DAILY_REQUEST_SOFT_LIMIT=900
MASTER_PRESS_GROQ_DAILY_TOKEN_SOFT_LIMIT=450000
MASTER_PRESS_GROQ_MINUTE_TOKEN_SOFT_LIMIT=5400

# OpenRouter handles only privacy-minimized case judgments.
OPENROUTER_API_MYKEY=YOUR_OPENROUTER_API_KEY
# Legacy fallback names are still accepted: MASTER_PRESS_OPENROUTER_API_KEY, OPENROUTER_API_KEY
MASTER_PRESS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MASTER_PRESS_OPENROUTER_CASE_MODEL=google/gemma-4-26b-a4b-it:free
MASTER_PRESS_OPENROUTER_DAILY_SOFT_LIMIT=800

# Operational limits and retention.
MASTER_PRESS_DATA_DIR=PoC/04-master-press/data
MASTER_PRESS_PER_RUN_ARTICLE_LIMIT=20
MASTER_PRESS_ARTICLE_BODY_LIMIT=15000
MASTER_PRESS_REQUEST_TIMEOUT=10
MASTER_PRESS_RAW_RETENTION_DAYS=7
MASTER_PRESS_METADATA_RETENTION_DAYS=90
MASTER_PRESS_RSS_FEEDS_JSON=[]


# MOIS press-release Markdown RAG (first organization).
MASTER_PRESS_MOIS_PRESS_RSS_URL=https://www.mois.go.kr/gpms/view/jsp/rss/rss.jsp?ctxCd=1012
MASTER_PRESS_PRESS_SYNC_MINUTES=30
MASTER_PRESS_PRESS_PER_SYNC=8
MASTER_PRESS_PRESS_MATCH_WINDOW_DAYS=45
MASTER_PRESS_PRESS_MATCH_THRESHOLD=62

# Existing shared Supabase values are reused for optional metadata mirroring.
SUPABASE2_URL=https://YOUR_PROJECT.supabase.co
SUPABASE2_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
