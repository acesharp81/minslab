# Copy this file to .env for local development.
# Never commit .env or real service keys.

# OpenRouter Settings > Keys에서 확인합니다.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase 프로젝트 Settings > API에서 확인합니다.
SUPABASE2_URL=https://YOUR_PROJECT.supabase.co

# 브라우저에서 사용하는 공개 키입니다. PoC 03 런타임 설정 API가 전달합니다.
SUPABASE2_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# 백엔드 systemd 서비스에서만 사용하세요. 브라우저에 노출하면 안 됩니다.
SUPABASE2_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 선택: 법정동 역지오코딩을 사용하려면 둘 중 하나를 설정합니다.
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
VWORLD_API_KEY=YOUR_VWORLD_API_KEY

# 선택: 로컬 Ollama 서버 주소입니다.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 선택: OpenRouter 임베딩 모델을 바꾸고 싶을 때만 설정합니다.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# 선택: Cohere reranking 활성화 시 사용합니다.
COHERE_API_KEY=YOUR_COHERE_API_KEY
COHERE_RERANK_MODEL=rerank-v4.0-fast

# PoC/01-AISafeAgent 설정입니다.
# 실제 값은 .env에만 넣고 커밋하지 마세요.
HF_API_KEY=YOUR_HUGGINGFACE_ROUTER_API_KEY
KMA_AUTH_KEY=YOUR_KMA_API_HUB_AUTH_KEY
# KMA_AUTH_KEY가 JSON을 반환하지 않으면 API Hub에서 승인된 초단기예보 endpoint를 확인해 이 값을 바꾸세요.
KMA_ULTRA_SHORT_URL=https://apihub-pub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0/getUltraSrtFcst
KMA_ULTRA_NCST_URL=https://apihub-pub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0/getUltraSrtNcst
HF_BASE_URL=https://router.huggingface.co/v1
AI_SAFE_AGENT_MODEL=Qwen/Qwen3.6-35B-A3B
AI_SAFE_HF_QWEN25_MODEL=Qwen/Qwen2.5-72B-Instruct
AI_SAFE_OPENROUTER_MODEL=openai/gpt-4o-mini
# 비워두면 PoC 폴더의 최신 integrated_disaster_kb_YYYYMMDD_HHMMSS.pkl을 자동 사용합니다.
DISASTER_KB_PATH=

# PoC/01-AISafeAgent 공공데이터 수집 키입니다.
SAFETYDATA_SHELTER_KEY=YOUR_SAFETYDATA_SHELTER_KEY
SAFETYDATA_LANDSLIDE_KEY=YOUR_SAFETYDATA_LANDSLIDE_KEY
SAFETYDATA_VULNERABLE_KEY=YOUR_SAFETYDATA_VULNERABLE_KEY
SAFETYDATA_FLOOD_KEY=YOUR_SAFETYDATA_FLOOD_KEY

# PoC/02-field-inspection-platform 공개 클라이언트 설정입니다.
# VITE_ 값은 브라우저 번들에 포함되므로 service-role 키를 넣지 마세요.
VITE_FIELD_INSPECTION_SUPABASE_URL=https://YOUR_FIELD_INSPECTION_PROJECT.supabase.co
VITE_FIELD_INSPECTION_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# PoC/03-mois-kms는 위 SUPABASE2_URL, SUPABASE2_PUBLISHABLE_KEY,
# SUPABASE2_SERVICE_ROLE_KEY를 기존 MinsLab 프로젝트에서 함께 사용합니다.

# 선택: PoC 03 보고서 모델 목록과 기본 모델입니다. 쉼표로 여러 모델을 지정합니다.
MOIS_KMS_HF_MODELS=Qwen/Qwen2.5-72B-Instruct
MOIS_KMS_OPENROUTER_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash
MOIS_KMS_DEFAULT_MODEL=ollama:qwen2.5:1.5b

# 프로젝트 03 계층형 멀티에이전트 하네스 모델과 provider 실행 슬롯입니다.
MULTI_AGENT_HF_MODELS=Qwen/Qwen2.5-72B-Instruct
MULTI_AGENT_OPENROUTER_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash
MULTI_AGENT_DEFAULT_MODEL=ollama:qwen2.5:1.5b

# 현재 서버는 GPU가 없으므로 Local LLM 동시성은 1을 권장합니다.
MULTI_AGENT_OLLAMA_CONCURRENCY=1
MULTI_AGENT_HF_CONCURRENCY=1
MULTI_AGENT_OPENROUTER_CONCURRENCY=2

# 실제 LLM 계층형 실행은 모델 설정에서 아래 암호를 인증해야 합니다.
# 공개 비용 보호 기본값: 동시 실행 1개, 시간당 1회, 실행당 모델 호출 8회.
# 실제 값은 .env에만 저장하고 저장소에는 커밋하지 마세요.
MULTI_AGENT_LIVE_ENABLED_key=CHANGE_THIS_LIVE_EXECUTION_PASSWORD
MULTI_AGENT_LIVE_RUNS_PER_HOUR=1
MULTI_AGENT_LIVE_MAX_SECONDS=300
MULTI_AGENT_LIVE_CALL_TIMEOUT=120
MULTI_AGENT_LIVE_MAX_TOKENS=600

# MinsLab 방문 통계와 관리자 화면입니다.
# 실제 암호와 세션 비밀값은 .env에만 저장하세요.
MINSLAB_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
MINSLAB_ADMIN_SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET
MINSLAB_ANALYTICS_DB=data/analytics.sqlite3
# 원본 IP 방문 이벤트 보존일입니다. 일별 누적 통계는 계속 유지됩니다.
MINSLAB_ANALYTICS_RETENTION_DAYS=90
