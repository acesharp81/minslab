# Copy this file to .env for local development.
# Never commit .env or real service keys.

# OpenRouter Settings > Keys에서 확인합니다.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase 프로젝트 Settings > API에서 확인합니다.
SUPABASE2_URL=https://YOUR_PROJECT.supabase.co

# 백엔드 systemd 서비스에서만 사용하세요. 브라우저에 노출하면 안 됩니다.
SUPABASE2_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 선택: 법정동 역지오코딩을 사용하려면 둘 중 하나를 설정합니다.
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
VWORLD_API_KEY=YOUR_VWORLD_API_KEY

# 선택: 로컬 Ollama 서버 주소입니다.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 선택: OpenRouter 임베딩 모델을 바꾸고 싶을 때만 설정합니다.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# 선택: Cohere reranking 활성화 시 사용합니다.
COHERE_API_KEY=YOUR_COHERE_API_KEY
COHERE_RERANK_MODEL=rerank-v4.0-fast

# PoC/01-AISafeAgent 설정입니다.
# 실제 값은 .env에만 넣고 커밋하지 마세요.
HF_API_KEY=YOUR_HUGGINGFACE_ROUTER_API_KEY
KMA_AUTH_KEY=YOUR_KMA_API_HUB_AUTH_KEY
# KMA_AUTH_KEY가 JSON을 반환하지 않으면 API Hub에서 승인된 초단기예보 endpoint를 확인해 이 값을 바꾸세요.
KMA_ULTRA_SHORT_URL=https://apihub-pub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0/getUltraSrtFcst
KMA_ULTRA_NCST_URL=https://apihub-pub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0/getUltraSrtNcst
HF_BASE_URL=https://router.huggingface.co/v1
AI_SAFE_AGENT_MODEL=Qwen/Qwen3.6-35B-A3B
AI_SAFE_HF_QWEN25_MODEL=Qwen/Qwen2.5-72B-Instruct
AI_SAFE_OPENROUTER_MODEL=openai/gpt-4o-mini
# 비워두면 PoC 폴더의 최신 integrated_disaster_kb_YYYYMMDD_HHMMSS.pkl을 자동 사용합니다.
DISASTER_KB_PATH=

# PoC/01-AISafeAgent 공공데이터 수집 키입니다.
SAFETYDATA_SHELTER_KEY=YOUR_SAFETYDATA_SHELTER_KEY
SAFETYDATA_LANDSLIDE_KEY=YOUR_SAFETYDATA_LANDSLIDE_KEY
SAFETYDATA_VULNERABLE_KEY=YOUR_SAFETYDATA_VULNERABLE_KEY
SAFETYDATA_FLOOD_KEY=YOUR_SAFETYDATA_FLOOD_KEY
